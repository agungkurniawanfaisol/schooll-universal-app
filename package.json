{
  "name": "sekolah-app",
  "private": true,
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0"
  },
  "lint-staged": {
    "frontend/src/**/*.{ts,tsx}": [
      "bash -c 'cd frontend && npm run typecheck'"
    ],
    "backend/**/*.php": [
      "bash -c 'cd backend && ./vendor/bin/pint --test'"
    ]
  }
}
