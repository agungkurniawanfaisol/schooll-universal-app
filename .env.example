# Application
APP_ENV=local
APP_DEBUG=false

# Docker Ports
BACKEND_PORT=8000
VITE_PORT=5173
MYSQL_PORT=3306
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# Database
DB_DATABASE=sekolah_cms
DB_USERNAME=sekolah
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# Auth — token expiry in minutes (default: 7 days)
SANCTUM_TOKEN_EXPIRATION=10080

# Frontend
VITE_API_URL=http://localhost:8000/api/v1
